// WebFlowAI — data model
// PostgreSQL + Prisma. Designed for multi-tenant SaaS scale:
// every hot query path is backed by an index, and large append-only
// tables (Message, Generation, UsageEvent) are partition-friendly.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Identity
// ─────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  avatarUrl String?
  bio       String?
  role      UserRole @default(MEMBER)

  // Onboarding
  onboarded     Boolean @default(false)
  primaryUseCase String?

  // AI credit accounting (denormalized for fast reads)
  creditsBalance Int @default(200)
  creditsMonthly Int @default(200)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects      Project[]
  subscription  Subscription?
  usageEvents   UsageEvent[]
  apiKeys       ApiKey[]
  messages      Message[]

  @@index([clerkId])
  @@index([email])
}

enum UserRole {
  ADMIN
  MEMBER
}

// ─────────────────────────────────────────────────────────────
// Projects
// ─────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  name        String
  slug        String
  description String?
  status      ProjectStatus @default(DRAFT)
  framework   String        @default("next")
  templateId  String?
  prompt      String? // original generation prompt
  thumbnail   String?

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  files       File[]
  messages    Message[]
  generations Generation[]
  deployments Deployment[]
  usageEvents UsageEvent[]

  lastOpenedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([ownerId, slug])
  @@index([ownerId, updatedAt])
  @@index([status])
}

enum ProjectStatus {
  DRAFT
  GENERATING
  READY
  ERROR
  ARCHIVED
}

// File tree stored as flat rows; `path` is the source of truth for hierarchy.
model File {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  path      String // e.g. "src/app/page.tsx"
  content   String  @db.Text
  language  String?
  isBinary  Boolean @default(false)
  size      Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, path])
  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────
// Conversation + AI generation
// ─────────────────────────────────────────────────────────────

model Message {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  role    MessageRole
  content String      @db.Text
  // Structured tool calls / agent steps rendered in the chat UI.
  parts   Json?

  createdAt DateTime @default(now())

  generation Generation?

  @@index([projectId, createdAt])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model Generation {
  id        String           @id @default(cuid())
  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messageId String?          @unique
  message   Message?         @relation(fields: [messageId], references: [id], onDelete: SetNull)

  status    GenerationStatus @default(PENDING)
  // The multi-agent plan + per-agent step traces.
  plan      Json?
  steps     Json?

  model        String?
  promptTokens Int     @default(0)
  outputTokens Int     @default(0)
  creditsCost  Int     @default(0)
  durationMs   Int     @default(0)
  error        String?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([projectId, createdAt])
  @@index([status])
}

enum GenerationStatus {
  PENDING
  PLANNING
  ARCHITECTING
  GENERATING
  APPLYING
  REVIEWING
  COMPLETED
  FAILED
}

// ─────────────────────────────────────────────────────────────
// Deployments
// ─────────────────────────────────────────────────────────────

model Deployment {
  id        String           @id @default(cuid())
  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  status   DeploymentStatus @default(QUEUED)
  url      String?
  provider String           @default("webflowai")
  commitSha String?
  logs     String?          @db.Text

  createdAt DateTime  @default(now())
  readyAt   DateTime?

  @@index([projectId, createdAt])
}

enum DeploymentStatus {
  QUEUED
  BUILDING
  READY
  FAILED
  CANCELED
}

// ─────────────────────────────────────────────────────────────
// Billing (Razorpay-first, provider-agnostic)
// ─────────────────────────────────────────────────────────────

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan         Plan               @default(FREE)
  status       SubscriptionStatus @default(ACTIVE)
  billingCycle BillingCycle       @default(MONTHLY)

  provider             BillingProvider @default(RAZORPAY)
  razorpayCustomerId   String?
  razorpaySubscriptionId String?       @unique
  // Reserved for future Stripe support.
  stripeCustomerId     String?
  stripeSubscriptionId String?

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

enum Plan {
  FREE
  PRO
  TEAM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
  TRIALING
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum BillingProvider {
  RAZORPAY
  STRIPE
}

model Payment {
  id             String        @id @default(cuid())
  subscriptionId String
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  amount   Int // in paise
  currency String        @default("INR")
  status   PaymentStatus @default(CREATED)
  method   String? // upi, card, netbanking

  razorpayPaymentId String? @unique
  razorpayOrderId   String?
  invoiceUrl        String?

  createdAt DateTime @default(now())

  @@index([subscriptionId, createdAt])
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}

// ─────────────────────────────────────────────────────────────
// Usage metering + API keys
// ─────────────────────────────────────────────────────────────

model UsageEvent {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)

  type    UsageType
  credits Int       @default(0)
  tokens  Int       @default(0)
  meta    Json?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

enum UsageType {
  GENERATION
  CHAT_MESSAGE
  DEPLOYMENT
  PREVIEW_BUILD
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  prefix    String   // visible prefix, e.g. "wfa_live_xxxx"
  hashedKey String   @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}
