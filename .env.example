# Database (matches docker-compose.yml)
DATABASE_URL="postgresql://webflowai:webflowai@localhost:5432/webflowai?schema=public"

# AI — this project uses Azure OpenAI. Without a key the app runs in demo mode.
# Provide the key as OPENAI_API_KEY (or AZURE_OPENAI_API_KEY — either works).
OPENAI_API_KEY=""
# Azure resource name (the subdomain in <name>.openai.azure.com).
AZURE_RESOURCE_NAME="genai-lav1sh-resource"
# WEBFLOWAI_MODEL must be your Azure *deployment* name (not the base model id).
WEBFLOWAI_MODEL="gpt-5.5-1"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# Razorpay (India-first billing)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
