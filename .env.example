# Database (matches docker-compose.yml)
DATABASE_URL="postgresql://webflowai:webflowai@localhost:5432/webflowai?schema=public"

# AI — this project uses Google Vertex AI (express mode, API-key auth).
GOOGLE_VERTEX_API_KEY=""

# WEBFLOWAI_MODEL is the Vertex model name (e.g. gemini-3.1-pro-preview,
WEBFLOWAI_MODEL="gemini-3.1-pro-preview"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

