# Database (matches docker-compose.yml)
DATABASE_URL="postgresql://webflowai:webflowai@localhost:5432/webflowai?schema=public"

# AI — this project uses Google Vertex AI (express mode, API-key auth).
# Without a key the app runs in demo mode. Get an express-mode API key from
# the Google Cloud console (Vertex AI in express mode).
GOOGLE_VERTEX_API_KEY=""
# WEBFLOWAI_MODEL is the Vertex model name (e.g. gemini-2.5-flash,
# gemini-2.5-pro, gemini-3.1-pro-preview).
WEBFLOWAI_MODEL="gemini-2.5-flash"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Razorpay (India-first billing)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

